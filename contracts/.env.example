# Sepolia RPC
SEPOLIA_RPC_URL=https://rpc.sepolia.org

# Deployer private key (DO NOT commit real keys)
PRIVATE_KEY=0x...

# Etherscan API key (for contract verification)
ETHERSCAN_API_KEY=...

# Admin addresses (multi-sig signers)
ADMIN_1=0x...
ADMIN_2=0x...
ADMIN_3=0x...

# Threshold (minimum signatures required, default: 2)
THRESHOLD=2
